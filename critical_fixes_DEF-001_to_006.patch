+    for candidate in [
+        ExecutionProvider::Cuda,
+        ExecutionProvider::DirectMl,
+        ExecutionProvider::CoreMl,
+    ] {
+        if probe_provider(candidate, model_path, PROBE_BUDGET) {
+            return candidate;
+        }
+    }
